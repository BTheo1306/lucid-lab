# =============================================================================
# Lucid-Lab Chat Bot — Environment Variables (reference)
# =============================================================================
# Copy this into .env.local (local dev) and add to Vercel for staging / prod.

# -------- Supabase (new dedicated project) --------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...                 # server-only — never expose

# -------- AI provider --------
AI_PROVIDER=anthropic                             # anthropic | openai | gemini | mistral
AI_MODEL=claude-sonnet-4-5-20260115
ANTHROPIC_API_KEY=sk-ant-...
# Fallback providers (optional)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=

# -------- Lead enrichment --------
APOLLO_API_KEY=

# -------- TidyCal (booking) --------
# Leave TIDYCAL_API_KEY / TIDYCAL_BOOKING_TYPE_ID empty to run in "public URL"
# fallback mode — the bot simply sends visitors to TIDYCAL_PUBLIC_URL.
TIDYCAL_API_KEY=
TIDYCAL_BOOKING_TYPE_ID=
TIDYCAL_PUBLIC_URL=https://tidycal.com/lucid-lab/audit-flash-30-minutes

# -------- Email (SMTP) --------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true                                  # true for 465, false for 587/25
SMTP_USER=info@lucid-lab.fr
SMTP_PASS=                                        # Google App Password (16 chars)
EMAIL_FROM=info@lucid-lab.fr
TEAM_NOTIFICATION_EMAIL=info@lucid-lab.fr

# -------- Widget / origin check --------
CHAT_ALLOWED_ORIGIN=https://lucid-lab.fr,https://www.lucid-lab.fr,http://localhost:3000
NEXT_PUBLIC_CHAT_API_URL=                         # optional — defaults to same-origin

# -------- Cloudflare Turnstile (optional — skip = no abuse protection) --------
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -------- Admin + cron auth --------
ADMIN_API_KEY=                                    # random 32+ char string
CRON_SECRET=                                      # random 32+ char string

# -------- DocuSeal documents/signature --------
DOCUSEAL_API_BASE_URL=https://docuseal-production-xxxx.up.railway.app/api
DOCUSEAL_PROXY_ORIGIN=https://docuseal-production-xxxx.up.railway.app/api
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_BON_DE_COMMANDE_TEMPLATE_ID=2
DOCUSEAL_COMPLETED_REDIRECT_URL=https://lucid-lab.fr

# -------- Google Drive archive --------
# Use OAuth refresh-token vars OR service-account vars depending on deployment.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_IMPERSONATED_USER=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# -------- Obsidian sync (local/admin only) --------
LUCID_OS_OBSIDIAN_VAULT_PATH=

# -------- Budget + rate limit --------
BILLING_DEFAULT_VAT_RATE=20
DAILY_AI_BUDGET_EUR=10
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SEC=600

# -------- GDPR retention (days) --------
RETENTION_MESSAGES_DAYS=365
RETENTION_LEADS_LOST_DAYS=365
RETENTION_AUDIT_LOG_DAYS=730

# -------- Runtime --------
NODE_ENV=development
IP_HASH_SALT=change-me-to-a-random-string
