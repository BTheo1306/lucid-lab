"""
Generate a Lucid-Lab branded .docx template that imports cleanly into Google Docs.

Run: python3 scripts/generate-google-doc-template.py
"""

from pathlib import Path

from docx import Document
from docx.enum.section import WD_SECTION_START
from docx.enum.table import WD_CELL_VERTICAL_ALIGNMENT, WD_TABLE_ALIGNMENT
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.oxml import OxmlElement
from docx.oxml.ns import qn
from docx.shared import Cm, Inches, Pt, RGBColor


ROOT = Path(__file__).resolve().parents[1]
OUTPUT_DIR = ROOT / "docs"
OUTPUT_PATH = OUTPUT_DIR / "lucid-lab-google-doc-template.docx"
LOGO_PATH = ROOT / "public" / "logo.png"

COLORS = {
    "paper": "F7F5F1",
    "ink": "0A0A0A",
    "muted": "666666",
    "soft": "E5E5E5",
    "white": "FFFFFF",
    "amber": "FFB451",
    "sand": "EFC680",
    "blue": "B4D8FF",
    "ice": "D2E8FF",
    "pale": "FAFDFF",
    "black": "000000",
    "emerald": "34D399",
    "violet": "A78BFA",
}


def rgb(hex_color: str) -> RGBColor:
    clean = hex_color.strip("#")
    return RGBColor(int(clean[0:2], 16), int(clean[2:4], 16), int(clean[4:6], 16))


def set_run_font(run, *, family="Inter", size=None, bold=None, italic=None, color=None):
    run.font.name = family
    run._element.rPr.rFonts.set(qn("w:eastAsia"), family)
    if size is not None:
        run.font.size = Pt(size)
    if bold is not None:
        run.bold = bold
    if italic is not None:
        run.italic = italic
    if color is not None:
        run.font.color.rgb = rgb(color)


def set_cell_shading(cell, fill_hex: str):
    cell_properties = cell._tc.get_or_add_tcPr()
    shading = OxmlElement("w:shd")
    shading.set(qn("w:fill"), fill_hex)
    cell_properties.append(shading)


def set_cell_padding(cell, top=120, start=120, bottom=120, end=120):
    cell_properties = cell._tc.get_or_add_tcPr()
    margins = cell_properties.first_child_found_in("w:tcMar")
    if margins is None:
        margins = OxmlElement("w:tcMar")
        cell_properties.append(margins)
    for edge, value in (("top", top), ("start", start), ("bottom", bottom), ("end", end)):
        element = margins.find(qn(f"w:{edge}"))
        if element is None:
            element = OxmlElement(f"w:{edge}")
            margins.append(element)
        element.set(qn("w:w"), str(value))
        element.set(qn("w:type"), "dxa")


def set_cell_border(cell, *, top=None, bottom=None, start=None, end=None):
    cell_properties = cell._tc.get_or_add_tcPr()
    borders = cell_properties.first_child_found_in("w:tcBorders")
    if borders is None:
        borders = OxmlElement("w:tcBorders")
        cell_properties.append(borders)
    for edge, color in (("top", top), ("bottom", bottom), ("start", start), ("end", end)):
        if color is None:
            continue
        element = borders.find(qn(f"w:{edge}"))
        if element is None:
            element = OxmlElement(f"w:{edge}")
            borders.append(element)
        element.set(qn("w:val"), "single")
        element.set(qn("w:sz"), "8")
        element.set(qn("w:space"), "0")
        element.set(qn("w:color"), color)


def clear_paragraph(paragraph):
    paragraph._element.clear_content()


def set_paragraph_spacing(paragraph, before=0, after=0, line=1.15):
    paragraph.paragraph_format.space_before = Pt(before)
    paragraph.paragraph_format.space_after = Pt(after)
    paragraph.paragraph_format.line_spacing = line


def add_brand_lockup(paragraph, logo_width=0.27, text_size=13, dark=False):
    run_logo = paragraph.add_run()
    run_logo.add_picture(str(LOGO_PATH), width=Inches(logo_width))
    text_run = paragraph.add_run("  Lucid-Lab")
    set_run_font(
        text_run,
        family="Syne",
        size=text_size,
        bold=True,
        color=COLORS["white"] if dark else COLORS["ink"],
    )


def add_accent_strip(doc):
    table = doc.add_table(rows=1, cols=5)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    widths = [1.25, 1.25, 1.25, 1.25, 1.25]
    for index, color_key in enumerate(("amber", "sand", "blue", "ice", "pale")):
        cell = table.cell(0, index)
        cell.width = Inches(widths[index])
        set_cell_shading(cell, COLORS[color_key])
        set_cell_padding(cell, top=20, start=0, bottom=20, end=0)
        set_cell_border(cell, top=COLORS[color_key], bottom=COLORS[color_key], start=COLORS[color_key], end=COLORS[color_key])
        clear_paragraph(cell.paragraphs[0])
        cell.paragraphs[0].add_run(" ")
    return table


def add_small_label(paragraph, text, color=COLORS["muted"]):
    set_paragraph_spacing(paragraph, before=0, after=4)
    label_run = paragraph.add_run(text.upper())
    set_run_font(label_run, family="Inter", size=8, bold=True, color=color)


def add_heading(doc, text, number=None):
    paragraph = doc.add_paragraph()
    set_paragraph_spacing(paragraph, before=18, after=8, line=1.05)
    if number:
        number_run = paragraph.add_run(f"{number}  ")
        set_run_font(number_run, family="Inter", size=9, bold=True, color="BBBBBB")
    heading_run = paragraph.add_run(text)
    set_run_font(heading_run, family="Inter", size=19, bold=True, color=COLORS["ink"])
    return paragraph


def add_body(doc, text, *, color=COLORS["muted"], after=8, bold=False):
    paragraph = doc.add_paragraph()
    set_paragraph_spacing(paragraph, before=0, after=after, line=1.45)
    body_run = paragraph.add_run(text)
    set_run_font(body_run, family="Inter", size=10.5, bold=bold, color=color)
    return paragraph


def add_bullet(doc, text, *, color=COLORS["muted"]):
    paragraph = doc.add_paragraph(style="List Bullet")
    set_paragraph_spacing(paragraph, before=0, after=4, line=1.35)
    clear_paragraph(paragraph)
    run = paragraph.add_run(text)
    set_run_font(run, family="Inter", size=10, color=color)
    return paragraph


def add_callout(doc, title, body, accent=COLORS["amber"]):
    table = doc.add_table(rows=1, cols=2)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    table.columns[0].width = Inches(0.16)
    table.columns[1].width = Inches(6.0)

    accent_cell = table.cell(0, 0)
    content_cell = table.cell(0, 1)
    set_cell_shading(accent_cell, accent)
    set_cell_shading(content_cell, COLORS["white"])
    set_cell_padding(accent_cell, top=0, start=0, bottom=0, end=0)
    set_cell_padding(content_cell, top=160, start=190, bottom=160, end=190)
    set_cell_border(accent_cell, top=accent, bottom=accent, start=accent, end=accent)
    set_cell_border(content_cell, top=COLORS["soft"], bottom=COLORS["soft"], start=COLORS["soft"], end=COLORS["soft"])

    title_paragraph = content_cell.paragraphs[0]
    clear_paragraph(title_paragraph)
    set_paragraph_spacing(title_paragraph, after=5)
    title_run = title_paragraph.add_run(title)
    set_run_font(title_run, family="Inter", size=12.5, bold=True, color=COLORS["ink"])

    body_paragraph = content_cell.add_paragraph()
    set_paragraph_spacing(body_paragraph, after=0, line=1.35)
    body_run = body_paragraph.add_run(body)
    set_run_font(body_run, family="Inter", size=9.5, color=COLORS["muted"])
    return table


def add_metadata_table(doc):
    table = doc.add_table(rows=4, cols=2)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    labels = ("Client", "Document", "Date", "Owner")
    values = ("[Nom du client]", "Audit Flash IA", "14 mai 2026", "Lucid-Lab")
    for row_index, (label, value) in enumerate(zip(labels, values)):
        label_cell = table.cell(row_index, 0)
        value_cell = table.cell(row_index, 1)
        label_cell.width = Inches(1.35)
        value_cell.width = Inches(4.85)
        set_cell_shading(label_cell, COLORS["black"])
        set_cell_shading(value_cell, COLORS["white"])
        set_cell_padding(label_cell, top=125, start=160, bottom=125, end=140)
        set_cell_padding(value_cell, top=125, start=160, bottom=125, end=160)
        set_cell_border(label_cell, top=COLORS["black"], bottom=COLORS["black"], start=COLORS["black"], end=COLORS["black"])
        set_cell_border(value_cell, top=COLORS["soft"], bottom=COLORS["soft"], start=COLORS["soft"], end=COLORS["soft"])
        label_paragraph = label_cell.paragraphs[0]
        value_paragraph = value_cell.paragraphs[0]
        clear_paragraph(label_paragraph)
        clear_paragraph(value_paragraph)
        label_run = label_paragraph.add_run(label.upper())
        value_run = value_paragraph.add_run(value)
        set_run_font(label_run, family="Inter", size=7.5, bold=True, color=COLORS["white"])
        set_run_font(value_run, family="Inter", size=9.5, color=COLORS["ink"])
    return table


def add_system_card(cell, label, title, body, accent):
    set_cell_shading(cell, COLORS["black"])
    set_cell_padding(cell, top=180, start=180, bottom=180, end=180)
    set_cell_border(cell, top=COLORS["black"], bottom=COLORS["black"], start=COLORS["black"], end=COLORS["black"])
    cell.vertical_alignment = WD_CELL_VERTICAL_ALIGNMENT.TOP

    label_paragraph = cell.paragraphs[0]
    clear_paragraph(label_paragraph)
    set_paragraph_spacing(label_paragraph, after=12)
    label_run = label_paragraph.add_run(label.upper())
    set_run_font(label_run, family="Inter", size=7.5, bold=True, color=accent)

    title_paragraph = cell.add_paragraph()
    set_paragraph_spacing(title_paragraph, after=6, line=1.15)
    title_run = title_paragraph.add_run(title)
    set_run_font(title_run, family="Inter", size=12, bold=True, color=COLORS["white"])

    body_paragraph = cell.add_paragraph()
    set_paragraph_spacing(body_paragraph, after=0, line=1.3)
    body_run = body_paragraph.add_run(body)
    set_run_font(body_run, family="Inter", size=8.5, color="B8B8B8")


def add_three_card_row(doc):
    table = doc.add_table(rows=1, cols=3)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    for cell in table.rows[0].cells:
        cell.width = Inches(2.0)
    add_system_card(
        table.cell(0, 0),
        "01 Cartographie",
        "Chaos vers carte claire",
        "Process, frictions, outils et priorites sont rendus lisibles avant toute construction.",
        COLORS["amber"],
    )
    add_system_card(
        table.cell(0, 1),
        "02 Build",
        "Systemes en production",
        "Automatisations, agents IA et interfaces metier livres pour usage reel, pas pour demo.",
        COLORS["violet"],
    )
    add_system_card(
        table.cell(0, 2),
        "03 Scale",
        "Equipe autonome",
        "Documentation, gouvernance et passation pour que l'operation continue apres livraison.",
        COLORS["emerald"],
    )
    return table


def configure_styles(doc):
    normal_style = doc.styles["Normal"]
    normal_style.font.name = "Inter"
    normal_style._element.rPr.rFonts.set(qn("w:eastAsia"), "Inter")
    normal_style.font.size = Pt(10.5)
    normal_style.font.color.rgb = rgb(COLORS["ink"])

    for style_name in ("Heading 1", "Heading 2", "Heading 3"):
        style = doc.styles[style_name]
        style.font.name = "Inter"
        style._element.rPr.rFonts.set(qn("w:eastAsia"), "Inter")
        style.font.bold = True
        style.font.color.rgb = rgb(COLORS["ink"])


def configure_section(section):
    section.top_margin = Cm(1.65)
    section.bottom_margin = Cm(1.55)
    section.left_margin = Cm(2.15)
    section.right_margin = Cm(2.15)
    section.header_distance = Cm(0.8)
    section.footer_distance = Cm(0.75)


def add_header_footer(section):
    header = section.header
    header_paragraph = header.paragraphs[0]
    clear_paragraph(header_paragraph)
    add_brand_lockup(header_paragraph, logo_width=0.22, text_size=10.5)
    header_paragraph.alignment = WD_ALIGN_PARAGRAPH.LEFT

    footer = section.footer
    footer_paragraph = footer.paragraphs[0]
    clear_paragraph(footer_paragraph)
    set_paragraph_spacing(footer_paragraph, after=0)
    footer_run = footer_paragraph.add_run("lucid-lab.fr  ·  info@lucid-lab.fr  ·  Document confidentiel")
    set_run_font(footer_run, family="Inter", size=8, color="999999")


def add_cover(doc):
    add_accent_strip(doc)
    doc.add_paragraph()

    brand_paragraph = doc.add_paragraph()
    set_paragraph_spacing(brand_paragraph, before=18, after=38)
    add_brand_lockup(brand_paragraph, logo_width=0.34, text_size=16)

    eyebrow = doc.add_paragraph()
    add_small_label(eyebrow, "Template Google Docs · Lucid-Lab")

    title = doc.add_paragraph()
    set_paragraph_spacing(title, before=0, after=12, line=1.02)
    title_run = title.add_run("Audit Flash IA\nDocument client")
    set_run_font(title_run, family="Inter", size=34, bold=True, color=COLORS["ink"])

    subtitle = doc.add_paragraph()
    set_paragraph_spacing(subtitle, before=0, after=26, line=1.45)
    subtitle_run = subtitle.add_run(
        "Un format clair pour transformer un besoin operationnel en systeme IA concret, priorise et pret a construire."
    )
    set_run_font(subtitle_run, family="Inter", size=12, color=COLORS["muted"])

    add_metadata_table(doc)

    doc.add_paragraph()
    add_callout(
        doc,
        "On ne conseille pas. On construit.",
        "Ce modele sert de base pour les audits, propositions, comptes-rendus et documents clients Lucid-Lab.",
        accent=COLORS["blue"],
    )


def add_template_body(doc):
    doc.add_section(WD_SECTION_START.NEW_PAGE)
    configure_section(doc.sections[-1])
    add_header_footer(doc.sections[-1])

    add_heading(doc, "Resume executif", "01")
    add_body(
        doc,
        "[En 5 a 7 lignes : le contexte, le probleme a resoudre, la valeur attendue et la decision demandee.]",
    )
    add_body(
        doc,
        "Exemple : votre equipe perd du temps sur des taches recurrentes de qualification, de reporting et de relance. L'objectif est de connecter les sources existantes, automatiser les etapes repetitives et garder l'humain sur la validation commerciale.",
        color="333333",
    )

    add_heading(doc, "Diagnostic operationnel", "02")
    add_bullet(doc, "Friction principale : [decrire le point de blocage visible cote metier].")
    add_bullet(doc, "Impact business : [temps perdu, leads rates, erreurs, delais, couts caches].")
    add_bullet(doc, "Donnees disponibles : [CRM, emails, fichiers, formulaires, outils internes].")
    add_bullet(doc, "Risque a maitriser : [RGPD, qualite des donnees, adoption equipe, validation humaine].")

    add_callout(
        doc,
        "Principe de presentation",
        "Chaque document doit arriver vite au concret : ce qu'on a compris, ce qui bloque, ce qu'on construit, puis comment on le livre.",
        accent=COLORS["amber"],
    )

    add_heading(doc, "Architecture proposee", "03")
    add_three_card_row(doc)

    add_heading(doc, "Roadmap d'execution", "04")
    roadmap = doc.add_table(rows=4, cols=3)
    roadmap.alignment = WD_TABLE_ALIGNMENT.CENTER
    roadmap.autofit = False
    headers = ("Phase", "Livrable", "Decision attendue")
    rows = (
        ("Semaine 1", "Cartographie process + donnees", "Valider le perimetre"),
        ("Semaines 2-3", "Prototype automatise", "Tester avec l'equipe"),
        ("Semaine 4", "Mise en production + passation", "Activer le run"),
    )
    for column_index, header in enumerate(headers):
        cell = roadmap.cell(0, column_index)
        set_cell_shading(cell, COLORS["black"])
        set_cell_padding(cell, top=120, start=120, bottom=120, end=120)
        set_cell_border(cell, top=COLORS["black"], bottom=COLORS["black"], start=COLORS["black"], end=COLORS["black"])
        paragraph = cell.paragraphs[0]
        clear_paragraph(paragraph)
        run = paragraph.add_run(header.upper())
        set_run_font(run, family="Inter", size=7.5, bold=True, color=COLORS["white"])
    for row_index, row_values in enumerate(rows, start=1):
        for column_index, value in enumerate(row_values):
            cell = roadmap.cell(row_index, column_index)
            set_cell_shading(cell, COLORS["white"])
            set_cell_padding(cell, top=120, start=120, bottom=120, end=120)
            set_cell_border(cell, top=COLORS["soft"], bottom=COLORS["soft"], start=COLORS["soft"], end=COLORS["soft"])
            paragraph = cell.paragraphs[0]
            clear_paragraph(paragraph)
            run = paragraph.add_run(value)
            set_run_font(run, family="Inter", size=9, bold=column_index == 0, color=COLORS["ink"] if column_index == 0 else COLORS["muted"])

    add_heading(doc, "Prochaines etapes", "05")
    add_body(doc, "1. Confirmer le perimetre prioritaire et les parties prenantes.", color="333333")
    add_body(doc, "2. Donner acces aux sources necessaires ou fournir un export de travail.", color="333333")
    add_body(doc, "3. Planifier l'atelier de lancement et verrouiller la date de premiere livraison.", color="333333")

    add_callout(
        doc,
        "Signature",
        "Lucid-Lab · Operational Strategy, Software Dev & IA Engineering · lucid-lab.fr",
        accent=COLORS["ice"],
    )


def build_document():
    doc = Document()
    configure_styles(doc)
    for section in doc.sections:
        configure_section(section)
        add_header_footer(section)
    add_cover(doc)
    add_template_body(doc)
    return doc


def main():
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    document = build_document()
    document.save(OUTPUT_PATH)
    print(f"Generated {OUTPUT_PATH.relative_to(ROOT)}")


if __name__ == "__main__":
    main()